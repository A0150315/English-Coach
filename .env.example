# Secrets for the LOCAL hook scripts. Copy to .env and fill in. Never commit .env.
# The hook (hook/lib.js) loads this file at startup — nothing needs to be in global env.

# NetEase AIGW bearer token (your gateway token)
COACH_AIGW_TOKEN=put-your-aigw-bearer-token-here

# AIGW endpoint + model. AIGW is reachable from 内网 only. Override only if your gateway differs.
COACH_AIGW_URL=https://aigw.nie.netease.com/v1/chat/completions
COACH_AIGW_MODEL=deepseek-v4-flash

# Your deployed Pages URL (set after first deploy). The suffix (-7et etc.) is assigned by Cloudflare.
COACH_API_URL=https://english-coach-7et.pages.dev

# Shared secret between hook and the Pages Functions write endpoints
COACH_API_KEY=change-me-to-a-random-string
